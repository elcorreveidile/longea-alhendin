# --- Base de datos (Neon / Postgres) ---
# Cadena de conexión de Neon (la encuentras en el panel de Neon -> Connection string)
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"

# --- Sesión ---
# Secreto para firmar las cookies de sesión. Genera uno con:  openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# --- Correo (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Remitente verificado en Resend (mientras pruebas puedes usar onboarding@resend.dev)
EMAIL_FROM="Cuadrantes <onboarding@resend.dev>"

# --- Administradoras ---
# Correos que entran automáticamente como administradoras (separados por comas).
# AQUÍ va el correo de Diana cuando lo tengas:
ADMIN_EMAILS="diana@ejemplo.com"

# --- URL pública de la app ---
# En local: http://localhost:3000  ·  En Vercel se detecta sola, pero puedes fijarla.
APP_URL="http://localhost:3000"
