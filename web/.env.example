# --- Base de datos (Neon / Postgres) ---
# Cadena de conexión de Neon (la encuentras en el panel de Neon -> Connection string)
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"

# --- Sesión ---
# Secreto para firmar las cookies de sesión. Genera uno con:  openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# --- Correo (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Remitente verificado en Resend (mientras pruebas puedes usar onboarding@resend.dev)
EMAIL_FROM="Cuadrantes <onboarding@resend.dev>"

# --- SMS (LabsMobile, proveedor español) ---
# Crea cuenta en labsmobile.com -> API: usuario (tu email) y token API.
# Si lo dejas vacío, en desarrollo el código se imprime en consola (no se envía).
LABSMOBILE_USERNAME="tu-email@ejemplo.com"
LABSMOBILE_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"
# Remitente opcional (nombre que ve quien recibe el SMS). Déjalo vacío si no tienes uno.
SMS_SENDER=""

# --- Administradoras ---
# Correos y/o móviles que entran automáticamente como administradoras (comas).
# AQUÍ van el correo y el móvil de Diana (el móvil en formato +34...):
ADMIN_EMAILS="diana@ejemplo.com"
ADMIN_PHONES="+34600000000"

# Súper administrador(es): control total, por encima de las administradoras.
SUPERADMIN_EMAILS="benitezl@go.ugr.es"

# --- URL pública de la app ---
# En local: http://localhost:3000  ·  En Vercel se detecta sola, pero puedes fijarla.
APP_URL="http://localhost:3000"
